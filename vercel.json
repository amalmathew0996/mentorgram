{
  "crons": [
    {
      "path": "/api/refresh-jobs",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/send-jobs-digest",
      "schedule": "0 14 * * 5"
    },
    {
      "path": "/api/send-reminders",
      "schedule": "0 9 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
