{
  "rewrites": [
    {
      "source": "/api/admin-stats",
      "destination": "/api/admin-stats"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/refresh-jobs",
      "schedule": "0 */2 * * *"
    }
  ]
}
