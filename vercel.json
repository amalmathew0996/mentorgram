{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/guide",
      "destination": "/guide.html"
    },
    {
      "source": "/ai-mentor",
      "destination": "/index.html"
    },
    {
      "source": "/education",
      "destination": "/index.html"
    },
    {
      "source": "/universities",
      "destination": "/index.html"
    },
    {
      "source": "/jobs",
      "destination": "/index.html"
    },
    {
      "source": "/visa-sponsors",
      "destination": "/index.html"
    },
    {
      "source": "/contact",
      "destination": "/index.html"
    },
    {
      "source": "/profile",
      "destination": "/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/index.html"
    },
    {
      "source": "/terms",
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/refresh-jobs",
      "schedule": "0 2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sponsorship-guide.pdf",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/pdf"
        },
        {
          "key": "Content-Disposition",
          "value": "inline; filename=Mentorgram_Sponsorship_Guide.pdf"
        }
      ]
    },
    {
      "source": "/logo.png",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    }
  ]
}
